{
  "expo": {
    "name": "今日、〇〇できた？ -Did you ___ today?-",
    "slug": "kaomoji-diary",
    "version": "1.1.0",
    "scheme": "kaomojiDiary",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.keisone.kaomojiDiary",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#66bb6a",
          "defaultChannel": "reminder"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4395545227647434~2792613047"
        }
      ],
      "./plugins/withKotlinSkipMetadataCheck"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bc4a0712-5b74-4c15-b177-44fb3275952f"
      }
    },
    "owner": "keisone"
  }
}
